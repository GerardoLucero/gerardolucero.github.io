---
import BaseLayout from "../components/layout/BaseLayout.astro";
---

<BaseLayout title="404 — Not Found">
  <div class="not-found">
    <div class="container">
      <div class="not-found-content">
        <div class="error-code">
          <span class="c-keyword">throw</span>
          <span class="c-class"> new </span>
          <span class="c-fn">NotFoundError</span>
          <span class="c-op">(</span>
          <span class="c-string">"404"</span>
          <span class="c-op">);</span>
        </div>
        <h1>Page not found</h1>
        <p>The route you're looking for doesn't exist or has been moved.</p>
        <a href="/" class="btn btn-primary">← Back home</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100vh - 128px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 0;
  }

  .not-found-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .error-code {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 3vw, 1.5rem);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem 2rem;
    margin-bottom: 1rem;
  }

  .c-keyword { color: #c792ea; }
  .c-class   { color: var(--color-text-muted); }
  .c-fn      { color: #82aaff; }
  .c-op      { color: #89ddff; }
  .c-string  { color: #c3e88d; }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.03em;
  }

  p {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 1rem;
  }
</style>
