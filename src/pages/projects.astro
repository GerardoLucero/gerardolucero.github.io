---
import BaseLayout from "../components/layout/BaseLayout.astro";
import RepoGrid from "../components/projects/RepoGrid";
import ContributionHeatmap from "../components/projects/ContributionHeatmap";

const NPM_PACKAGES = [
  "calcula-rfc","calcula-curp","calculadora-isr","calculadora-nomina-mx",
  "calculadora-imss","calculadora-iva","mx-bancos","mx-feriados",
  "mx-nombres","mx-codigos-postales","validador-fiscal-mx","validador-clabe",
  "calendario-fiscal-mx","generador-datos-mx",
];

// ── npm downloads (build-time) ─────────────────────────────────────────────
let totalNpmDownloads = 0;

try {
  const res = await fetch(
    `https://api.npmjs.org/downloads/point/last-month/${NPM_PACKAGES.join(",")}`
  );
  if (res.ok) {
    const data = await res.json();
    for (const pkg of NPM_PACKAGES) {
      totalNpmDownloads += data[pkg]?.downloads ?? 0;
    }
  }
} catch (_) {}

// ── GitHub commits (build-time) ────────────────────────────────────────────
let githubCommits = 0;

try {
  const year = new Date().getFullYear();
  const res = await fetch(
    `https://api.github.com/search/commits?q=author:GerardoLucero+committer-date:>${year}-01-01&per_page=1`,
    { headers: { Accept: "application/vnd.github.cloak-preview" } }
  );
  if (res.ok) githubCommits = (await res.json()).total_count ?? 0;
} catch (_) {}


// ── Lines of code total via codetabs ──────────────────────────────────────
let totalLinesOfCode = 0;

try {
  const reposRes = await fetch(
    "https://api.github.com/users/GerardoLucero/repos?per_page=100&type=owner",
    { headers: { Accept: "application/vnd.github.v3+json" } }
  );
  if (reposRes.ok) {
    const repos: Array<{ name: string; fork: boolean }> = await reposRes.json();
    const ownRepos = repos.filter(r => !r.fork).map(r => r.name);
    const CHUNK = 10;
    for (let i = 0; i < ownRepos.length; i += CHUNK) {
      const results = await Promise.allSettled(
        ownRepos.slice(i, i + CHUNK).map(repo =>
          fetch(`https://api.codetabs.com/v1/loc?github=GerardoLucero/${repo}`)
            .then(r => r.ok ? r.json() : [])
        )
      );
      for (const r of results) {
        if (r.status === "fulfilled" && Array.isArray(r.value)) {
          const total = r.value.find((l: { language: string; linesOfCode: number }) => l.language === "Total");
          if (total?.linesOfCode) totalLinesOfCode += total.linesOfCode;
        }
      }
    }
  }
} catch (_) {}

// ── GitHub contributions heatmap ──────────────────────────────────────────
type Contribution = { date: string; count: number; level: 0|1|2|3|4 };
let contributions: Contribution[] = [];

try {
  const res = await fetch(
    "https://github-contributions-api.jogruber.de/v4/GerardoLucero?y=last"
  );
  if (res.ok) {
    const data = await res.json();
    contributions = data.contributions ?? [];
  }
} catch (_) {}

// Build week columns for the heatmap
type Week = { month: string; days: (Contribution | null)[] };
const weeks: Week[] = [];

if (contributions.length > 0) {
  // Pad start so first day aligns to correct weekday (0=Sun)
  const firstDow = new Date(contributions[0].date).getDay();
  const padded: (Contribution | null)[] = [
    ...Array(firstDow).fill(null),
    ...contributions,
  ];
  for (let i = 0; i < padded.length; i += 7) {
    const days = padded.slice(i, i + 7);
    while (days.length < 7) days.push(null);
    const firstReal = days.find(d => d !== null);
    const month = firstReal
      ? new Date(firstReal.date).toLocaleString("en-US", { month: "short" })
      : "";
    weeks.push({ month, days });
  }
}

// Month labels: show label only on first week of each month
const monthLabels = weeks.map((w, i) => {
  if (i === 0) return w.month;
  return weeks[i - 1].month !== w.month ? w.month : "";
});

function fmt(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000)     return `${(n / 1_000).toFixed(1)}K`;
  return n.toString();
}

const statsBar = [
  { value: fmt(totalNpmDownloads) || "—", label: "npm downloads / month" },
  { value: NPM_PACKAGES.length.toString(), label: "npm packages" },
  { value: fmt(githubCommits) || "—",      label: `commits ${new Date().getFullYear()}` },
  { value: fmt(totalLinesOfCode) || "—",   label: "lines of code" },
];

---

<BaseLayout
  title="Projects"
  description="Open-source npm packages and GitHub projects by Gerardo Lucero — Mexican fiscal utilities, distributed systems tooling."
>
  <div class="projects-page">
    <div class="container">

      <header class="page-header animate-fade-in-up">
        <h1 class="page-title">Projects</h1>
        <p class="page-subtitle">
          Open-source packages on <a href="https://www.npmjs.com/~gerardolucero" target="_blank" rel="noopener">npm</a>
          and repositories on <a href="https://github.com/GerardoLucero" target="_blank" rel="noopener">GitHub</a>.
          Stats refreshed on every deploy.
        </p>
      </header>

      <!-- Stats bar -->
      <div class="stats-bar animate-fade-in-up delay-100">
        {statsBar.map(s => (
          <div class="stat-item">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>

      <!-- Contributions heatmap (client-side) -->
      <div class="contrib-section animate-fade-in-up delay-150">
        <div class="contrib-header">
          <span class="contrib-title">Contribution activity</span>
          <a href="https://github.com/GerardoLucero" target="_blank" rel="noopener" class="contrib-link">
            View on GitHub →
          </a>
        </div>
        <ContributionHeatmap username="GerardoLucero" client:load />
      </div>

      <!-- GitHub repos -->
      <section class="section animate-fade-in-up delay-300">
        <h2 class="section-title">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          GitHub repositories
        </h2>
        <RepoGrid username="GerardoLucero" client:load />
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .projects-page { padding: 4rem 0 2rem; }

  .page-header { margin-bottom: 2rem; }

  .page-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
  }

  .page-subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .page-subtitle a { color: var(--color-primary-light); text-decoration: none; }
  .page-subtitle a:hover { text-decoration: underline; }

  /* ── Stats bar ─────────────────────────────────────────── */
  .stats-bar {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem 1.75rem;
    margin-bottom: 1rem;
  }

  .stat-item { display: flex; flex-direction: column; gap: 0.2rem; min-width: 100px; }

  .stat-value {
    font-size: 1.4rem;
    font-weight: 800;
    font-family: var(--font-mono);
    color: var(--color-heading);
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── Contributions heatmap ─────────────────────────────── */
  .contrib-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }

  .contrib-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .contrib-title {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .contrib-link {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contrib-link:hover { color: var(--color-primary-light); }


  /* ── Sections ──────────────────────────────────────────── */
  .section { margin-bottom: 3.5rem; }

  .section-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 1rem;
  }

  .section-title svg { color: var(--color-text-muted); flex-shrink: 0; }

  /* ── Repo grid (Preact component) ──────────────────────── */
  :global(.repo-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  :global(.repo-card) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  :global(.repo-card:hover) {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px color-mix(in srgb, var(--color-primary) 12%, transparent);
  }

  :global(.repo-header) { display: flex; align-items: center; gap: 0.5rem; }
  :global(.repo-icon) { color: var(--color-text-muted); flex-shrink: 0; }

  :global(.repo-name) {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary-light);
    font-family: var(--font-mono);
  }

  :global(.repo-desc) {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.repo-topics) { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  :global(.repo-topic) {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-accent) 10%, var(--color-surface-light));
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  :global(.repo-footer) {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  :global(.repo-lang) { display: flex; align-items: center; gap: 0.35rem; font-size: 0.75rem; color: var(--color-text-muted); }
  :global(.lang-dot) { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  :global(.repo-stat) { display: flex; align-items: center; gap: 0.3rem; font-size: 0.75rem; color: var(--color-text-muted); }
  :global(.repo-updated) { font-size: 0.7rem; color: var(--color-text-muted); font-family: var(--font-mono); margin-left: auto; }

  :global(.loading-grid) { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem; }

  :global(.repo-skeleton) {
    height: 160px;
    border-radius: 12px;
    background: linear-gradient(90deg, var(--color-surface) 25%, var(--color-surface-light) 50%, var(--color-surface) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border: 1px solid var(--color-border);
  }

  :global(.repo-error), :global(.repo-empty) {
    padding: 3rem;
    text-align: center;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: 12px;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (max-width: 600px) {
    .stats-bar { gap: 1rem; padding: 1rem; }
    .stat-value { font-size: 1.2rem; }
    .loc-bar { padding: 0.75rem 1rem; }
  }
</style>
