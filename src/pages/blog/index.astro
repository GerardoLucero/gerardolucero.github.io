---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout
  title="Blog"
  description="Technical articles by Gerardo Lucero on distributed systems, cloud architecture, DevSecOps and platform engineering."
>
  <div class="blog-page">
    <div class="container">

      <header class="page-header animate-fade-in-up">
        <h1 class="page-title">Blog</h1>
        <p class="page-subtitle">
          Thoughts on distributed systems, cloud architecture, and the craft of building software.
        </p>
      </header>

      <div class="posts-list animate-fade-in-up delay-100">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-meta">
              <time class="post-date">{formatDate(post.data.pubDate)}</time>
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="badge badge-accent">{tag}</span>
                ))}
              </div>
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
            <span class="post-read">Read article →</span>
          </a>
        ))}
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .blog-page { padding: 4rem 0 2rem; }

  .page-header { margin-bottom: 3rem; }

  .page-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
  }

  .page-subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 600px;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }

  .post-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0;
    line-height: 1.3;
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .post-read {
    font-size: 0.85rem;
    color: var(--color-primary-light);
    font-weight: 500;
    font-family: var(--font-mono);
    margin-top: 0.25rem;
  }
</style>
