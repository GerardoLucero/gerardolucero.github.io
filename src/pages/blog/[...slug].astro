---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <div class="post-page">
    <div class="container">

      <div class="post-nav animate-fade-in-up">
        <a href="/blog" class="back-link">← All articles</a>
      </div>

      <header class="post-header animate-fade-in-up delay-100">
        <div class="post-meta">
          <time class="post-date">{formatDate(post.data.pubDate)}</time>
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="badge badge-accent">{tag}</span>
            ))}
          </div>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-desc">{post.data.description}</p>
      </header>

      <article class="post-content animate-fade-in-up delay-200">
        <Content />
      </article>

      <script>
        import mermaid from "mermaid";
        mermaid.initialize({
          startOnLoad: false,
          theme: "dark",
          themeVariables: {
            darkMode: true,
            background: "#0d1117",
            primaryColor: "#1e2a3a",
            primaryTextColor: "#c9d1d9",
            primaryBorderColor: "#30363d",
            lineColor: "#58a6ff",
            secondaryColor: "#161b22",
            tertiaryColor: "#21262d",
            fontFamily: "ui-monospace, SFMono-Regular, monospace",
            fontSize: "13px",
            nodeBorder: "#30363d",
            clusterBkg: "#161b22",
            titleColor: "#e6edf3",
            edgeLabelBackground: "#161b22",
            attributeBackgroundColorEven: "#161b22",
            attributeBackgroundColorOdd: "#21262d",
          },
        });
        document.addEventListener("DOMContentLoaded", () => {
          mermaid.run({ nodes: document.querySelectorAll(".mermaid") });
        });
      </script>

      <footer class="post-footer animate-fade-in-up delay-300">
        <div class="author-card">
          <div class="author-info">
            <span class="author-name">Gerardo Lucero</span>
            <span class="author-title">Solutions Architect | DevSecOps Engineer</span>
          </div>
          <div class="author-links">
            <a href="https://linkedin.com/in/luceroriosg" target="_blank" rel="noopener" class="btn btn-outline btn-sm">LinkedIn</a>
            <a href="mailto:luceroriosg@gmail.com" class="btn btn-primary btn-sm">Get in touch</a>
          </div>
        </div>
        <a href="/blog" class="back-link">← All articles</a>
      </footer>

    </div>
  </div>
</BaseLayout>

<style>
  .post-page { padding: 4rem 0 2rem; }

  .post-nav { margin-bottom: 2rem; }

  .back-link {
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-primary-light); }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .post-date {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .post-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  .post-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0 0 1rem;
    color: var(--color-heading);
  }

  .post-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
    max-width: 680px;
  }

  /* ── Prose styles ── */
  .post-content {
    max-width: 720px;
    line-height: 1.8;
    font-size: 1rem;
    color: var(--color-text);
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.02em;
  }

  .post-content :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-heading);
    margin: 2rem 0 0.75rem;
  }

  .post-content :global(p) {
    margin: 0 0 1.25rem;
    color: var(--color-text-muted);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
    color: var(--color-text-muted);
  }

  .post-content :global(li) { margin-bottom: 0.4rem; }

  .post-content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .post-content :global(em) { color: var(--color-text); }

  .post-content :global(a) {
    color: var(--color-primary-light);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .post-content :global(pre) {
    background: var(--color-surface) !important;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .post-content :global(code:not(pre code)) {
    background: var(--color-surface-light);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    font-size: 0.875em;
    color: var(--color-accent);
    font-family: var(--font-mono);
  }

  /* ── Mermaid diagrams ── */
  .post-content :global(.mermaid-diagram) {
    margin: 0 0 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: #0d1117;
    padding: 1.5rem;
    overflow-x: auto;
  }

  .post-content :global(.mermaid-diagram pre.mermaid) {
    background: transparent !important;
    border: none !important;
    border-radius: 0 !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex;
    justify-content: center;
  }

  .post-content :global(.mermaid-diagram svg) {
    max-width: 100%;
    height: auto;
  }

  .post-content :global(.mermaid-diagram .mermaid-error) {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.25rem;
    margin: 0 0 1.25rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* ── Footer ── */
  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .author-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .author-name {
    font-weight: 700;
    color: var(--color-heading);
    font-size: 0.95rem;
  }

  .author-title {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .author-links { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .btn-sm {
    font-size: 0.8rem;
    padding: 0.4rem 1rem;
  }

  @media (max-width: 600px) {
    .author-card { flex-direction: column; align-items: flex-start; }
  }
</style>
