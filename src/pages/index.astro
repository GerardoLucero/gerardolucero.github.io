---
import BaseLayout from "../components/layout/BaseLayout.astro";
import { siteData } from "../data/site-data";
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow animate-fade-in-up">
          <span class="eyebrow-dot"></span>
          <span>Open to new opportunities</span>
        </div>

        <h1 class="hero-name animate-fade-in-up delay-100">
          {siteData.name}
        </h1>

        <h2 class="hero-title animate-fade-in-up delay-200">
          <span class="gradient-text">Solutions Architect</span>
          <span class="hero-separator"> & </span>
          <span>Technical PM</span>
        </h2>

        <p class="hero-summary animate-fade-in-up delay-300">
          {siteData.summary}
        </p>

        <div class="hero-actions animate-fade-in-up delay-400">
          <a href="/cv" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14,2 14,8 20,8"/>
            </svg>
            View CV
          </a>
          <a href="/projects" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
            Projects
          </a>
        </div>

        <!-- Stats -->
        <div class="hero-stats animate-fade-in-up delay-500">
          {siteData.highlights.map((h) => (
            <div class="stat">
              <span class="stat-value">{h.value}</span>
              <span class="stat-label">{h.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Decorative code block -->
      <div class="hero-code animate-fade-in delay-300">
        <div class="code-header">
          <span class="code-dot red"></span>
          <span class="code-dot yellow"></span>
          <span class="code-dot green"></span>
          <span class="code-filename">architect.ts</span>
        </div>
        <pre class="code-body"><code><span class="c-keyword">const</span> <span class="c-var">gerardo</span> <span class="c-op">=</span> {"{"}
  <span class="c-prop">role</span><span class="c-op">:</span> <span class="c-string">"Solutions Architect"</span>,
  <span class="c-prop">experience</span><span class="c-op">:</span> <span class="c-string">"7+ years"</span>,
  <span class="c-prop">stack</span><span class="c-op">:</span> [
    <span class="c-string">"Kafka"</span>, <span class="c-string">"Kubernetes"</span>,
    <span class="c-string">"AWS"</span>, <span class="c-string">"GCP"</span>,
  ],
  <span class="c-prop">focus</span><span class="c-op">:</span> <span class="c-string">"Distributed Systems"</span>,
  <span class="c-prop">available</span><span class="c-op">:</span> <span class="c-bool">true</span>,
{"}"}<span class="c-op">;</span></code></pre>
      </div>
    </div>
  </section>

  <!-- Focus Areas -->
  <section class="section focus-section">
    <div class="container">
      <h2 class="section-title">What I do</h2>
      <div class="focus-grid">
        {siteData.focusAreas.map((area, i) => (
          <div class:list={["card focus-card", `delay-${(i + 1) * 100}`]}>
            <div class="focus-icon">{area.icon}</div>
            <h3 class="focus-title">{area.title}</h3>
            <p class="focus-desc">{area.description}</p>
            <div class="focus-tags">
              {area.tags.map((tag) => (
                <span class="badge badge-primary">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="section stack-section">
    <div class="container">
      <h2 class="section-title">Tech Stack</h2>
      <div class="stack-grid">
        <div class="stack-group">
          <span class="stack-category">Cloud & Infra</span>
          <div class="stack-badges">
            {["AWS", "GCP", "Azure DevOps", "Kubernetes", "OpenShift", "Docker", "Terraform"].map(t => (
              <span class="badge">{t}</span>
            ))}
          </div>
        </div>
        <div class="stack-group">
          <span class="stack-category">Streaming & Messaging</span>
          <div class="stack-badges">
            {["Apache Kafka", "SQS", "Pub/Sub", "Event-driven"].map(t => (
              <span class="badge">{t}</span>
            ))}
          </div>
        </div>
        <div class="stack-group">
          <span class="stack-category">Observability</span>
          <div class="stack-badges">
            {["Dynatrace", "Grafana", "Prometheus", "SLO/SLI", "Distributed Tracing"].map(t => (
              <span class="badge">{t}</span>
            ))}
          </div>
        </div>
        <div class="stack-group">
          <span class="stack-category">Languages & Frameworks</span>
          <div class="stack-badges">
            {["Java", "Python", "JavaScript", "Node.js", "Spring Boot", "React.js"].map(t => (
              <span class="badge">{t}</span>
            ))}
          </div>
        </div>
        <div class="stack-group">
          <span class="stack-category">DevSecOps</span>
          <div class="stack-badges">
            {["GitHub Actions", "SAST", "DAST", "Policy-as-Code", "CI/CD"].map(t => (
              <span class="badge">{t}</span>
            ))}
          </div>
        </div>
        <div class="stack-group">
          <span class="stack-category">Data</span>
          <div class="stack-badges">
            {["MongoDB", "PostgreSQL", "DynamoDB", "Firebase"].map(t => (
              <span class="badge">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-card">
        <div class="cta-content">
          <h2>Let's build something together</h2>
          <p>Looking for a solutions architect or technical PM? I'd love to hear about your challenges.</p>
        </div>
        <div class="cta-actions">
          <a href="mailto:luceroriosg@gmail.com" class="btn btn-primary">Send a message</a>
          <a href="/cv" class="btn btn-outline">View full CV</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ────────────────────────────── */
  .hero {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    padding: 5rem 0 3rem;
    position: relative;
  }

  .hero::after {
    content: "";
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle at center,
      color-mix(in srgb, var(--color-primary) 8%, transparent),
      transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    margin-bottom: 1rem;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    width: fit-content;
  }

  .eyebrow-dot {
    width: 6px; height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    animation: blink 2s infinite;
  }

  .hero-name {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    color: var(--color-heading);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0 0 0.25rem;
  }

  .hero-title {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
    color: var(--color-text-muted);
  }

  .hero-separator { color: var(--color-border-light); margin: 0 0.25rem; }

  .hero-summary {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 520px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-stats {
    display: flex;
    gap: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .stat { display: flex; flex-direction: column; gap: 0.15rem; }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-heading);
    font-family: var(--font-mono);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── Code block ─────────────────────── */
  .hero-code {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    font-family: var(--font-mono);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 0 1px var(--color-border);
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface-light);
    border-bottom: 1px solid var(--color-border);
  }

  .code-dot {
    width: 12px; height: 12px;
    border-radius: 50%;
  }
  .code-dot.red    { background: #ff5f57; }
  .code-dot.yellow { background: #febc2e; }
  .code-dot.green  { background: #28c840; }

  .code-filename {
    margin-left: auto;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .code-body {
    margin: 0;
    padding: 1.5rem;
    font-size: 0.85rem;
    line-height: 1.9;
    background: transparent;
  }

  .code-body code {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-text);
    font-size: inherit;
  }

  .c-keyword { color: #c792ea; }
  .c-var     { color: #82aaff; }
  .c-op      { color: #89ddff; }
  .c-prop    { color: #f07178; }
  .c-string  { color: #c3e88d; }
  .c-bool    { color: #ff9cac; }

  /* ── Sections ────────────────────────── */
  .section { padding: 5rem 0; }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .focus-card { display: flex; flex-direction: column; gap: 0.75rem; }

  .focus-icon {
    font-size: 1.5rem;
    color: var(--color-primary);
  }

  .focus-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0;
  }

  .focus-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    flex: 1;
    margin: 0;
  }

  .focus-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  /* ── Stack ───────────────────────────── */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .stack-group {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
  }

  .stack-category {
    display: block;
    font-size: 0.7rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .stack-badges { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  /* ── CTA ─────────────────────────────── */
  .cta-card {
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--color-primary) 8%, var(--color-surface)),
      color-mix(in srgb, var(--color-accent) 5%, var(--color-surface))
    );
    border: 1px solid color-mix(in srgb, var(--color-primary) 25%, transparent);
    border-radius: 16px;
    padding: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .cta-content p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .cta-actions { display: flex; gap: 0.75rem; flex-shrink: 0; flex-wrap: wrap; }

  /* ── Responsive ──────────────────────── */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-code { display: none; }
    .focus-grid { grid-template-columns: 1fr; }
    .stack-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .hero { padding: 3rem 0 2rem; min-height: auto; }
    .cta-card { padding: 2rem 1.5rem; flex-direction: column; }
    .cta-actions { width: 100%; }
    .hero-stats { gap: 1.5rem; }
  }
</style>
